<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SonoGuard.Views.DetallePage"
             Title="Detalle de Evidencia"
             BackgroundColor="#1A1A2E">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Border StrokeShape="RoundRectangle 20"
                    Stroke="#0F3460" BackgroundColor="#16213E" Padding="24">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">

                    <Image Source="ruidologo.png"
                           WidthRequest="72" HeightRequest="72"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"/>

                    <Label x:Name="LabelNivelGrande"
                           FontSize="56" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"/>

                    <Label x:Name="LabelNivelDesc"
                           FontSize="20" FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <Border x:Name="BadgeBorder"
                            StrokeShape="RoundRectangle 14"
                            Stroke="Transparent" Padding="12,6"
                            HorizontalOptions="Center">
                        <Label x:Name="LabelBadge"
                               TextColor="White" FontSize="13" FontAttributes="Bold"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 16"
                    Stroke="#0F3460" BackgroundColor="#16213E" Padding="20">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Información del Registro"
                           TextColor="White" FontSize="16" FontAttributes="Bold"/>
                    <BoxView HeightRequest="1" Color="#0F3460"/>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Fecha:" TextColor="#A0A0B0"
                               FontSize="13" VerticalOptions="Center"/>
                        <Label x:Name="LabelFecha" Grid.Column="1"
                               TextColor="White" FontSize="15"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Lugar:" TextColor="#A0A0B0"
                               FontSize="13" VerticalOptions="Start"/>
                        <Label x:Name="LabelUbicacion" Grid.Column="1"
                               TextColor="White" FontSize="15" LineBreakMode="WordWrap"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Detalle:" TextColor="#A0A0B0"
                               FontSize="13" VerticalOptions="Start"/>
                        <Label x:Name="LabelDescripcion" Grid.Column="1"
                               TextColor="White" FontSize="15" LineBreakMode="WordWrap"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Nivel:" TextColor="#A0A0B0"
                               FontSize="13" VerticalOptions="Center"/>
                        <Label x:Name="LabelNivelExacto" Grid.Column="1"
                               TextColor="White" FontSize="15" FontAttributes="Bold"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 16"
                    Stroke="#0F3460" BackgroundColor="#16213E" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Referencia OMS"
                           TextColor="White" FontSize="14" FontAttributes="Bold"/>
                    <BoxView HeightRequest="1" Color="#0F3460"/>
                    <Label Text="• Menos de 55 dB — Normal, no perjudicial"   TextColor="LightGreen" FontSize="13"/>
                    <Label Text="• 55–70 dB — Molestia moderada"              TextColor="Yellow"     FontSize="13"/>
                    <Label Text="• 70–85 dB — Daño auditivo a largo plazo"    TextColor="Orange"     FontSize="13"/>
                    <Label Text="• Más de 85 dB — Daño auditivo irreversible" TextColor="#FF5722"    FontSize="13"/>
                    <Label Text="• Más de 100 dB — Peligro inmediato"         TextColor="Red"        FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <Button x:Name="BtnConvertir"
                    Text="Convertir a Denuncia Formal"
                    Clicked="OnConvertirClicked"
                    BackgroundColor="#E94560" TextColor="White"
                    FontAttributes="Bold" CornerRadius="20"
                    HeightRequest="50" HorizontalOptions="Fill"/>

            <Button Text="Eliminar Registro"
                    Clicked="OnEliminarClicked"
                    BackgroundColor="Transparent" TextColor="#E94560"
                    BorderColor="#E94560" BorderWidth="1"
                    CornerRadius="20" HeightRequest="46"
                    HorizontalOptions="Fill"/>

            <Button Text="Volver"
                    Clicked="OnVolverClicked"
                    BackgroundColor="Transparent" TextColor="#A0A0B0"
                    FontSize="14" HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
