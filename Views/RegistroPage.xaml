<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SonoGuard.Views.RegistroPage"
             Title="Crear Cuenta"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="30,40,30,30" Spacing="10" VerticalOptions="Center">

            <Image Source="ruidologo.png"
                   WidthRequest="80" HeightRequest="80"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"/>

            <Label Text="Crea tu cuenta"
                   FontSize="26" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"/>

            <Label Text="Registra tus datos para comenzar"
                   FontSize="14" TextColor="#A0A0B0"
                   HorizontalOptions="Center" Margin="0,0,0,8"/>

            <Label Text="Nombre completo" TextColor="#A0A0B0" FontSize="12"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#0F3460" BackgroundColor="#16213E">
                <Entry x:Name="EntryNombre" Placeholder="Tu nombre"
                       TextColor="White" PlaceholderColor="#808090"
                       BackgroundColor="Transparent" Margin="12,0"/>
            </Border>

            <Label Text="Correo electrónico" TextColor="#A0A0B0" FontSize="12"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#0F3460" BackgroundColor="#16213E">
                <Entry x:Name="EntryEmail" Placeholder="correo@ejemplo.com"
                       Keyboard="Email" TextColor="White"
                       PlaceholderColor="#808090"
                       BackgroundColor="Transparent" Margin="12,0"/>
            </Border>

            <Label Text="Contraseña" TextColor="#A0A0B0" FontSize="12"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#0F3460" BackgroundColor="#16213E">
                <Entry x:Name="EntryPassword" Placeholder="Mínimo 6 caracteres"
                       IsPassword="True" TextColor="White"
                       PlaceholderColor="#808090"
                       BackgroundColor="Transparent" Margin="12,0"/>
            </Border>

            <Label Text="Confirmar contraseña" TextColor="#A0A0B0" FontSize="12"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#0F3460" BackgroundColor="#16213E">
                <Entry x:Name="EntryConfirmar" Placeholder="Repite tu contraseña"
                       IsPassword="True" TextColor="White"
                       PlaceholderColor="#808090"
                       BackgroundColor="Transparent" Margin="12,0"/>
            </Border>

            <Label x:Name="LabelMensaje" FontSize="13"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   IsVisible="False"/>

            <Button Text="Crear cuenta"
                    Clicked="OnRegistrarClicked"
                    BackgroundColor="#E94560" TextColor="White"
                    FontSize="16" FontAttributes="Bold"
                    CornerRadius="25" HeightRequest="52"
                    HorizontalOptions="Fill" Margin="0,8,0,0"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="¿Ya tienes cuenta?" TextColor="#A0A0B0"
                       FontSize="14" VerticalOptions="Center"/>
                <Button Text="Inicia sesión"
                        Clicked="OnLoginClicked"
                        BackgroundColor="Transparent" TextColor="#E94560"
                        FontSize="14" Padding="4,0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
