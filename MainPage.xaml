<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SonoGuard.MainPage"
             Title="SonoGuard"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="30,60,30,40" Spacing="20" VerticalOptions="Center">

            <Image Source="ruidologo.png"
                   WidthRequest="130" HeightRequest="130"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"/>

            <Label Text="SonoGuard"
                   FontSize="38" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"/>

            <Label Text="Detección y Denuncia de Ruido"
                   FontSize="15" TextColor="#A0A0B0"
                   HorizontalOptions="Center"/>

            <BoxView HeightRequest="1" Color="#0F3460" Margin="0,8"/>

            <Label Text="Mide el nivel de ruido de tu entorno en tiempo real, genera evidencia y presenta denuncias de forma sencilla."
                   TextColor="#C0C0D0" FontSize="14"
                   HorizontalTextAlignment="Center" LineHeight="1.5"/>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12" Margin="0,8">
                <Border Grid.Row="0" Grid.Column="0"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#0F3460" BackgroundColor="#16213E" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Micrófono" FontSize="12" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Medición en tiempo real"
                               FontSize="10" TextColor="#A0A0B0"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#0F3460" BackgroundColor="#16213E" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Evidencias" FontSize="12" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Historial de denuncias"
                               FontSize="10" TextColor="#A0A0B0"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#0F3460" BackgroundColor="#16213E" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Alertas" FontSize="12" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Vibración en nivel alto"
                               FontSize="10" TextColor="#A0A0B0"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#0F3460" BackgroundColor="#16213E" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Seguro" FontSize="12" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Datos locales cifrados"
                               FontSize="10" TextColor="#A0A0B0"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Button Text="Iniciar Sesión"
                    Clicked="OnIniciarSesionClicked"
                    BackgroundColor="#E94560" TextColor="White"
                    FontSize="16" FontAttributes="Bold"
                    CornerRadius="25" HeightRequest="52"
                    HorizontalOptions="Fill" Margin="0,10,0,0"/>

            <Button Text="Registrarse"
                    Clicked="OnRegistrarseClicked"
                    BackgroundColor="Transparent" TextColor="#E94560"
                    BorderColor="#E94560" BorderWidth="1.5"
                    CornerRadius="25" HeightRequest="48"
                    HorizontalOptions="Fill"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
